{
  "manifest_version": 3,
  "name": "Messenger Peace of Mind",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*.messenger.com/*", "*://*.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "logo.png",
      "48":  "logo.png",
      "128": "logo.png"
    }
  },
  "icons": {
    "16":  "logo.png",
    "48":  "logo.png",
    "128": "logo.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.messenger.com/*", "*://*.facebook.com/*"],
      "js": ["content.js"]
    }
  ]
}